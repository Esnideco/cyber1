    all_props LIKE "*9360feb5-f418-4baa-8175-e2a00bac4301*", "Directory Writers",
    all_props LIKE "*25a516ed-2fa0-40ea-a2d0-12923a21473a*", "Authentication Extensibility Administrator",
    all_props LIKE "*0b00bede-4072-4d22-b441-e7df02a1ef63*", "Authentication Extensibility Password Administrator",
    all_props LIKE "*aaf43236-0c0d-4d5f-883a-6955382ac081*", "B2C IEF Keyset Administrator",
    all_props LIKE "*59d46f88-662b-457b-bceb-5c3809e5908f*", "Lifecycle Workflows Administrator",
    all_props LIKE "*ecb2c6bf-0ab6-418e-bd87-7986f8d63bbe*", "Attribute Provisioning Administrator",
    all_props LIKE "*422218e4-db15-4ef9-bbe0-8afb41546d79*", "Attribute Provisioning Reader",
    all_props LIKE "*db506228-d27e-4b7d-95e5-295956d6615f*", "Agent ID Administrator",
    all_props LIKE "*d2562ede-74db-457e-a7b6-544e236ebb61*", "AI Administrator",
    all_props LIKE "*1fe13547-53f6-408d-ac04-7f8eed167b38*", "AI Reader",
    "unknown"
  )
| WHERE role_name != "unknown"
| EVAL initiator = COALESCE(
    `azure.auditlogs.properties.initiated_by.user.userPrincipalName`,
    `azure.auditlogs.properties.initiated_by.user.displayName`,
    `azure.auditlogs.properties.initiated_by.app.displayName`,
    "unknown"
  )
| EVAL initiator_name = `azure.auditlogs.properties.initiated_by.user.displayName`
| EVAL initiator_ip = `azure.auditlogs.properties.initiated_by.user.ipAddress`
| EVAL recipient_object_id = `azure.auditlogs.properties.target_resources.0.id`
| EVAL recipient_upn = COALESCE(
    `azure.auditlogs.properties.target_resources.0.user_principal_name`,
    `azure.auditlogs.properties.target_resources.1.user_principal_name`,
    `azure.auditlogs.properties.target_resources.2.user_principal_name`,
    `azure.auditlogs.properties.target_resources.3.user_principal_name`,
    "not_in_log"
  )
| EVAL severity = CASE(
    azure.auditlogs.operation_name IN (
      "Add member to role",
      "Add member to role outside of PIM (permanent)",
      "Add member to role in PIM completed (permanent)"
    ) AND initiator NOT IN ("MS-PIM", "MS-PIM-Fairfax"), "critical",
    azure.auditlogs.operation_name == "Add eligible member to role", "high",
    "high"
  )
| KEEP @timestamp, azure.auditlogs.operation_name, severity, role_name,
       initiator, initiator_name, initiator_ip,
       recipient_object_id, recipient_upn,
       all_props, azure.correlation_id
