FROM logs-azure.auditlogs*
| WHERE azure.auditlogs.operation_name IN (
    "Add member to role",
    "Add member to role outside of PIM (permanent)",
    "Add member to role in PIM completed (permanent)",
    "Add member to role in PIM completed (timebound)",
    "Add eligible member to role",
    "Add member to role completed (PIM activation)"
  )
  AND event.outcome == "success"
| EVAL all_props = CONCAT(
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.0.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.1.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.2.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.3.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.4.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.5.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.6.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.7.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.8.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.9.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.10.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.11.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.12.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.13.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.14.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.15.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.16.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.17.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.18.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.19.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.20.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.21.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.22.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.23.new_value`, ""), " | ",
    COALESCE(`azure.auditlogs.properties.target_resources.0.modified_properties.24.new_value`, "")
  )
| EVAL role_name = CASE(
    all_props LIKE "*62e90394-69f5-4237-9190-012177145e10*", "Global Administrator",
    all_props LIKE "*e8611ab8-c189-46e8-94e1-60213ab1f814*", "Privileged Role Administrator",
    all_props LIKE "*7be44c8a-adaf-4e2a-84d6-ab2649e08a13*", "Privileged Authentication Administrator",
    all_props LIKE "*c4e39bd9-1100-46d3-8c65-fb160da0071f*", "Authentication Administrator",
    all_props LIKE "*fe930be7-5e62-47db-91af-98c3a49a38b1*", "User Administrator",
    all_props LIKE "*194ae4cb-b126-40b2-bd5b-6091b380977d*", "Security Administrator",
    all_props LIKE "*5d6b6bb7-de71-4623-b4af-96380a352509*", "Security Reader",
    all_props LIKE "*5f2222b1-57c3-48ba-8ad5-d4759f1fde6f*", "Security Operator",
    all_props LIKE "*b1be1c3e-b65d-4f19-8427-f6fa0d97feb9*", "Conditional Access Administrator",
    all_props LIKE "*9b895d92-2cd3-44c7-9d02-a6ac2d5ea5c3*", "Application Administrator",
    all_props LIKE "*158c047a-c907-4556-b7ef-446551a6b5f7*", "Cloud Application Administrator",
    all_props LIKE "*cf1c38e5-3621-4004-a7cb-879624dced7c*", "Application Developer",
    all_props LIKE "*8ac3fc64-6eca-42ea-9e69-59f4c7b60eb2*", "Hybrid Identity Administrator",
