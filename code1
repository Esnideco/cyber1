    all_props LIKE "*e00e864a-17c5-4a4b-9c06-f5b95a8d5bd8*", "Partner Tier2 Support",
    all_props LIKE "*3a2c62db-5318-420d-8d74-23affee5d9d5*", "Intune Administrator",
    all_props LIKE "*45d8d3c5-c802-45c6-b32a-1d70b5e1e86e*", "Identity Governance Administrator",
    all_props LIKE "*7698a772-787b-4ac8-901f-60d6b08affd2*", "Cloud Device Administrator",
    all_props LIKE "*be2f45a1-457d-42af-a067-6ec1fa63bc45*", "External Identity Provider Administrator",
